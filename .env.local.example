# ---- Database (PostgreSQL) ----
# SUPABASE: in the dashboard click "Connect" (top bar). Use the "ORMs" / Prisma tab.
#   DATABASE_URL = the POOLED connection (Transaction mode, port 6543, add ?pgbouncer=true)
#   DIRECT_URL   = the DIRECT connection (Session mode, port 5432) — used for migrations
# Do NOT use the "Project URL" (https://xxxx.supabase.co) — that is the REST API, not the DB.
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# NEON instead? Use one URL for both (Neon pools natively):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# ---- Auth (NextAuth) ----
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Seed admin credentials (used by `npm run db:seed`)
ADMIN_EMAIL="admin@vestige.com"
ADMIN_PASSWORD="admin12345"

# ---- Google OAuth (optional sign-in) ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---- Stripe — https://dashboard.stripe.com/apikeys ----
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# From `stripe listen` (local) or the Stripe dashboard webhook (production)
STRIPE_WEBHOOK_SECRET=whsec_...

# The URL of your site (used for Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- Pre-launch passcode gate ----
# Passcode required to access the site before launch (defaults to "vestige123").
LAUNCH_PASSWORD=vestige123
# Set to "true" after launch to open the site to everyone (disables the gate).
LAUNCH_GATE_OPEN=false

# ---- Analytics cron ----
# Secret that authenticates the daily rollup job. On Vercel, set this and the
# platform sends it automatically as "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=replace-with-a-long-random-string

# ---- Email (Resend) — https://resend.com ----
# Create a free account, add an API key. For production, verify a sending
# domain and set EMAIL_FROM to an address on it. Left blank, emails are skipped.
RESEND_API_KEY=
EMAIL_FROM="Vestige <onboarding@resend.dev>"
